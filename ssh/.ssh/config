# ~/.ssh/config

Host *
    SetEnv TERM=xterm-256color
	AddKeysToAgent yes
	IdentitiesOnly yes
	ControlMaster auto
	ControlPersist 10m
	ControlPath ~/.ssh/cm-%r@%h:%p

Host bastion
    HostName 164.52.214.194
	User ashishj
	ForwardAgent yes
	IdentityFile ~/Projects/Secrets/secrets/secret.ssh_keys/bastion/id_rsa

Host developer
    HostName 10.16.242.8
    User ashishj
	ProxyJump bastion
	IdentityFile ~/Projects/Secrets/secrets/secret.ssh_keys/ashishj/id_rsa

Host sandbox
    HostName 10.16.242.6
    User x
	ProxyJump bastion
	IdentityFile ~/Projects/Secrets/secrets/secret.ssh_keys/ashishj/id_rsa

Host tamc
	HostName 43.204.103.106
	User bitnami
	IdentityFile ~/Projects/Algo-Trading/deploy/dev/keys/key.pem

Host github.com
    HostName github.com
    User git
    IdentityFile ~/Projects/Secrets/secrets/secret.ssh_keys/github/id_rsa

Host bitbucket.org
    HostName bitbucket.org
    User git
    IdentityFile ~/Projects/Secrets/secrets/secret.ssh_keys/bitbucket/id_rsa

Host a
	HostName 192.168.0.103
	User a
	IdentityFile ~/Projects/Secrets/secrets/secret.ssh_keys/peer/id_rsa

Host p
	HostName 192.168.0.100
	User a
	IdentityFile ~/Projects/Secrets/secrets/secret.ssh_keys/pi/id_rsa

